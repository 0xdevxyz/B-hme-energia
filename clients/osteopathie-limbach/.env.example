# Editor Backend – osteopathie-limbach
# Diese Datei dient als Vorlage. Die echte .env ist gitignored und liegt im
# gemounteten Client-Ordner. Nach Änderungen: App osteopathie-limbach-html in
# CapRover neu deployen (Container liest .env beim Start).

SITE_URL=https://html.osteopathie-limbach.de
EDITOR_EMAIL=mail@panoart360.de

# --- SMTP (für Editor-Login-Magic-Link & Kontaktformular) ---
# Ohne SMTP wird der Login-Magic-Link in die Container-Logs geschrieben (Fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Praxis Christoph Uhlmann <noreply@osteopathie-limbach.de>"
