# Editor Backend – osteopathie-limbach (Vorlage)
# Echte .env ist gitignored und liegt im gemounteten Client-Ordner.
# Nach Änderungen: App osteopathie-limbach-html in CapRover neu deployen.

SITE_URL=https://html.osteopathie-limbach.de
EDITOR_EMAIL=mail@panoart360.de

# Empfänger des Kontaktformulars (Terminanfragen) -> Praxis
CONTACT_EMAIL=mail@osteopathie-limbach.de

# --- SMTP: nötig für Kontaktformular-Versand UND Editor-Login-Magic-Link ---
# Ohne gültige Werte kann KEINE Mail versendet werden.
# Hinweise:
#  - Passwort mit Sonderzeichen (#, $, @ ...) in einfache Quotes setzen: SMTP_PASS='...'
#  - Viele Hoster (z. B. Alfahosting) verlangen: Absender (From) == SMTP_USER,
#    sonst "553 Sender address rejected".
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Praxis Christoph Uhlmann <postfach@osteopathie-limbach.de>"
