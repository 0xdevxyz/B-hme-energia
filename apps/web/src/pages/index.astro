        <div class="faq-item">
          <div class="faq-head" onclick="toggleFAQ(this)">
            <strong>Lohnt sich das für ein Einfamilienhaus?</strong>
            <div class="icon">+</div>
          </div>
          <div class="faq-body">
            <div>Ja, besonders wenn Sie eine moderne Heizung ohne hohe Einmalinvestition möchten. Statt der Anschaffung zahlen Sie eine planbare Rate inklusive Wartung und Service; Fördermittel werden berücksichtigt.</div>
          </div>
        </div>

        <div class="faq-item">
          <div class="faq-head" onclick="toggleFAQ(this)">
            <strong>Welche Vertragslaufzeiten sind üblich?</strong>
            <div class="icon">+</div>
          </div>
          <div class="faq-body">
            <div>Contracting-Verträge laufen typischerweise über mehrere Jahre, häufig 10 bis 15 Jahre, damit sich die Investition in die Anlage über die Laufzeit verteilt. Die konkrete Laufzeit wird vertraglich vereinbart.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="close">
    <div class="wrap">
      <div class="close-grid">
        <div>
          <h2>Bereit für sorgenfreie Wärme?</h2>
          <p>Sagen Sie uns kurz, um welches Objekt es geht — wir melden uns mit einem unverbindlichen Wärmekonzept.</p>
          <div class="side">
            <button class="btn btn-light">Beratung buchen ↗<span class="circ">→</span></button>
            <p><strong>☎ +49 (0) 371 XXXXXX</strong></p>
            <p><strong>info@waermewerk.de</strong></p>
          </div>
        </div>
        <div></div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer style="text-align:center;padding:32px 22px;color:var(--muted);font-size:0.85rem;border-top:1px solid var(--line)">
    <p>* Beispiel-/Richtwerte — im Projekt durch belegbare Zahlen ersetzen. Markenname & Kontakt sind Platzhalter.</p>
  </footer>

  <script>
    const state = { typ: 'efh', flaeche: 140, daemm: 95, alt: 0.32 };
    const grund = { efh: 28, mfh: 120, gew: 240 };

    function setState(key, val) {
      state[key] = val;
      updateSegments();
      calc();
    }

    function handleRange(el) {
      state.flaeche = parseInt(el.value);
      const p = ((state.flaeche - 50) / (2000 - 50)) * 100;
      el.style.setProperty('--p', p + '%');
      document.getElementById('flaecheVal').textContent = state.flaeche + ' m²';
      calc();
    }

    function updateSegments() {
      document.querySelectorAll('.seg button').forEach(btn => {
        btn.classList.remove('on');
      });
      document.querySelectorAll('.seg button').forEach(btn => {
        const val = btn.getAttribute('onclick');
        if (val.includes(state.typ) || val.includes(state.daemm) || val.includes(state.alt)) {
          btn.classList.add('on');
        }
      });
    }

    function calc() {
      const bedarf = state.flaeche * state.daemm;
      const arbeit = 0.11;
      const monat = (bedarf * arbeit) / 12 + grund[state.typ];
      const fmtE = n => Math.round(n / 5) * 5;
      const lo = fmtE(monat * 0.88);
      const hi = fmtE(monat * 1.12);
      document.getElementById('rate').textContent = 'ca. ' + lo.toLocaleString('de-DE') + ' – ' + hi.toLocaleString('de-DE');

      const contract = 0.08;
      const saved = (bedarf * (state.alt - contract)) / 1000;
      const pct = Math.round(((state.alt - contract) / state.alt) * 100);
      document.getElementById('co2').textContent = '−' + pct + ' %';
      document.getElementById('kg').textContent = saved.toFixed(1).replace('.', ',') + ' t';
    }

    function toggleFAQ(head) {
      const item = head.parentElement;
      item.classList.toggle('open');
    }

    // Init
    calc();
    charSplit();

    function charSplit() {
      const h1 = document.getElementById('heroTitle');
      const text = h1.textContent;
      h1.innerHTML = '';
      for (let char of text) {
        const sp = document.createElement('span');
        sp.className = 'ch';
        sp.textContent = char;
        h1.appendChild(sp);
      }
    }
  </script>
</body>
</html>