---
import { getPageData, getPosts, getCMSImageUrl } from '../lib/cms';

const pageData = await getPageData();
const posts = await getPosts();

const heroTitle = pageData?.hero?.title || 'Wärme, die einfach da ist';
const heroSubtitle = pageData?.hero?.subtitle || 'Wir planen, finanzieren, bauen und betreiben Ihre Wärmeversorgung — Sie genießen nur das Ergebnis.';
const heroImage = getCMSImageUrl(pageData?.hero?.backgroundImage?.url);
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Wärmecontracting für Privat und Gewerbe — geplant, finanziert, betrieben.">
  <title>Böhme Energia — Wärmecontracting Sachsen</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #F4F2EC;
      --forest: #2A3A2F;
      --forest-2: #33473A;
      --green: #3C684D;
      --green-2: #4F7747;
      --muted: #6E7B70;
      --ink: #1B2620;
      --line: rgba(43, 60, 49, 0.12);
      --sans: 'Hanken Grotesk', system-ui, sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--sans);
      background: var(--cream);
      color: var(--forest);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img, svg {
      display: block;
      max-width: 100%;
    }

    .wrap {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 22px;
    }

    section {
      padding: 80px 22px;
    }

    h2 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--forest);
      font-family: 'Cormorant Garamond', serif;
    }

    h3 {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(60, 104, 77, 0.1);
      color: var(--green);
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 0.78rem;
      font-weight: 600;
      width: fit-content;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-weight: 600;
      font-size: 0.92rem;
      padding: 8px 8px 8px 22px;
      border-radius: 999px;
      border: 1px solid transparent;
      cursor: pointer;
      transition: 0.28s;
    }

    .btn .circ {
      width: 38px;
      height: 38px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      flex: none;
    }

    .btn-primary {
      background: linear-gradient(100deg, var(--green), var(--green-2));
      color: #fff;
      box-shadow: 0 14px 30px -14px rgba(60, 104, 77, 0.7);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
    }

    .btn-light {
      background: rgba(255, 255, 255, 0.92);
      color: var(--forest);
    }

    .btn-light:hover {
      background: #fff;
      transform: translateY(-2px);
    }

    /* Hero */
    .hero {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      height: 100vh;
      min-height: 600px;
      background: linear-gradient(135deg, var(--forest), var(--forest-2));
      color: #fff;
      padding: 40px 20px;
      position: relative;
      overflow: hidden;
    }

    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 700;
      margin-bottom: 20px;
      font-family: 'Cormorant Garamond', serif;
    }

    .hero p {
      font-size: 1.12rem;
      max-width: 640px;
      margin: 0 auto 32px;
      opacity: 0.9;
    }

    .hero .cta-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Grid Layouts */
    .grid3 {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 22px;
      margin-top: 40px;
    }

    .card {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      transition: 0.28s;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    }

    .card img {
      width: 100%;
      height: 240px;
      object-fit: cover;
    }

    .card .content {
      padding: 20px;
    }

    .card h3 {
      font-size: 1.28rem;
      margin-bottom: 10px;
    }

    .card p {
      color: var(--muted);
      font-size: 0.92rem;
    }

    footer {
      text-align: center;
      padding: 32px 22px;
      color: var(--muted);
      font-size: 0.85rem;
      border-top: 1px solid var(--line);
      background: #fff;
    }

    @media (max-width: 560px) {
      section {
        padding: 50px 18px;
      }

      .hero h1 {
        font-size: clamp(1.8rem, 5vw, 2.8rem);
      }

      .hero .cta-row {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="pill">✦ Wärmecontracting · Privat & Gewerbe</div>
      <h1>{heroTitle}</h1>
      <p>{heroSubtitle}</p>
      <div class="cta-row">
        <button class="btn btn-primary">Rate berechnen ▶<span class="circ">→</span></button>
        <button class="btn btn-light">So funktioniert's →<span class="circ">→</span></button>
      </div>
    </div>
  </section>

  <!-- Solutions from CMS -->
  <section>
    <div class="wrap">
      <div class="pill">Unsere Lösungen</div>
      <h2>Maßgeschneidert für Ihr Objekt</h2>

      <div class="grid3">
        {pageData?.values?.map((val: any) => (
          <div class="card">
            {val.backgroundImage && (
              <img src={getCMSImageUrl(val.backgroundImage.url)} alt={val.title} />
            )}
            <div class="content">
              <h3>{val.title}</h3>
              <p>{val.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <p>© 2024 Böhme Energia GmbH. Alle Rechte vorbehalten. | <a href="/datenschutz">Datenschutz</a> | <a href="/impressum">Impressum</a></p>
  </footer>

  <script>
    // Hier können später Calculator + weitere Interaktionen kommen
    console.log('Website geladen');
  </script>
</body>
</html>
