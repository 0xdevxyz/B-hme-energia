<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Wärme, die einfach da ist. Wärmecontracting für Privat und Gewerbe — geplant, finanziert, betrieben. Jetzt Rate berechnen.">
  <title>Wärmewerk — Wärme als Rundum-Service</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #F4F2EC;
      --forest: #2A3A2F;
      --forest-2: #33473A;
      --green: #3C684D;
      --green-2: #4F7747;
      --muted: #6E7B70;
      --ink: #1B2620;
      --line: rgba(43, 60, 49, 0.12);
      --sans: 'Plus Jakarta Sans', system-ui, sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--sans);
      background: var(--cream);
      color: var(--forest);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img, svg {
      display: block;
      max-width: 100%;
    }

    .wrap {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 22px;
    }

    /* Buttons */
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(60, 104, 77, 0.1);
      color: var(--green);
      border-radius: 999px;
      padding: 6px 14px;
      font-size: 0.78rem;
      font-weight: 600;
      width: fit-content;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-weight: 600;
      font-size: 0.92rem;
      padding: 8px 8px 8px 22px;
      border-radius: 999px;
      border: 1px solid transparent;
      cursor: pointer;
      transition: 0.28s;
    }

    .btn .circ {
      width: 38px;
      height: 38px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      flex: none;
    }

    .btn-primary {
      background: linear-gradient(100deg, var(--green), var(--green-2));
      color: #fff;
      box-shadow: 0 14px 30px -14px rgba(60, 104, 77, 0.7);
    }

    .btn-primary .circ {
      background: linear-gradient(59deg, #567A5E, #78A873);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
    }

    .btn-light {
      background: rgba(255, 255, 255, 0.92);
      color: var(--forest);
    }

    .btn-light .circ {
      background: linear-gradient(59deg, #EEE, #CBCBCB);
    }

    .btn-light:hover {
      background: #fff;
      transform: translateY(-2px);
    }

    .btn-out {
      background: transparent;
      color: var(--forest);
      border-color: var(--line);
      padding: 13px 24px;
    }

    /* Hero */
    .hero-pad {
      padding: 14px;
    }

    .hero {
      display: flex;
      flex-direction: column;
      height: calc(100vh - 28px);
      min-height: 600px;
      border-radius: 34px;
      overflow: hidden;
      position: relative;
      background: var(--forest);
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      background: linear-gradient(135deg, #2A3A2F, #1F2D24);
    }

    .hero-bg .ph {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .hero-scrim {
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        radial-gradient(120% 80% at 50% 42%, rgba(16, 24, 19, 0.32), rgba(16, 24, 19, 0) 70%),
        linear-gradient(180deg, rgba(16, 24, 19, 0.62) 0%, rgba(16, 24, 19, 0.36) 30%, rgba(16, 24, 19, 0.38) 56%, rgba(16, 24, 19, 0.76) 100%);
    }

    .nav {
      position: relative;
      z-index: 2;
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 26px;
    }

    .navpill {
      display: flex;
      align-items: center;
      gap: 32px;
      background: rgba(18, 26, 21, 0.42);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 999px;
      padding: 8px 18px;
      color: #fff;
      font-size: 0.92rem;
    }

    .navpill .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 1rem;
    }

    .navpill .brand svg {
      width: 20px;
      height: 20px;
      color: var(--green);
    }

    .navpill .links {
      display: flex;
      gap: 18px;
      font-size: 0.88rem;
    }

    .navpill .links a {
      color: #fff;
      transition: 0.28s;
    }

    .navpill .links a:hover {
      color: var(--green);
    }

    .nav .btn-light {
      display: none;
    }

    .hero-center {
      position: relative;
      z-index: 2;
      width: 100%;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 0 20px 96px;
      max-width: 920px;
      margin: 0 auto;
    }

    .hero-center .badge {
      display: inline-block;
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.25);
      color: #fff;
      border-radius: 999px;
      padding: 8px 16px;
      font-size: 0.88rem;
      margin-bottom: 24px;
    }

    #heroTitle {
      color: #fff;
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 800;
      line-height: 1.1;
      text-shadow: 0 2px 34px rgba(0, 0, 0, 0.5);
      margin-bottom: 20px;
    }

    #heroTitle .ch {
      display: inline-block;
      opacity: 0;
      transform: translateY(16px);
      animation: chIn 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }

    @keyframes chIn {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .hero-center > p {
      color: rgba(255, 255, 255, 0.85);
      font-size: 1.12rem;
      max-width: 640px;
      margin-bottom: 32px;
      line-height: 1.6;
    }

    .hero-center .cta-row {
      display: flex;
      gap: 12px;
      justify-content: center;
    }

    .hero-bottom {
      position: relative;
      z-index: 2;
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 18px;
      padding: 0 26px 30px;
      margin-top: auto;
    }

    .fcard {
      background: rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(255, 255, 255, 0.3);
      border-radius: 26px;
      padding: 22px;
      color: #fff;
      flex: 1;
      max-width: 280px;
    }

    .fcard.left h3 {
      font-size: 3.2rem;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .fcard.left p {
      font-size: 0.88rem;
      opacity: 0.85;
      margin-bottom: 12px;
    }

    .fcard.left .pill {
      background: rgba(255, 255, 255, 0.3);
      color: #fff;
    }

    .fcard.right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .fcard.right .avatars {
      display: flex;
      gap: -6px;
    }

    .fcard.right .avatars img {
      width: 38px;
      height: 38px;
      border-radius: 999px;
      border: 2px solid #fff;
      margin-left: -6px;
    }

    .fcard.right .avatars img:first-child {
      margin-left: 0;
    }

    .fcard.right div {
      font-size: 0.92rem;
    }

    .fcard.right strong {
      display: block;
      font-weight: 700;
      margin-bottom: 4px;
    }

    /* Marquee */
    .marquee {
      background: var(--cream);
      padding: 18px 0;
      overflow: hidden;
      border-top: 1px solid var(--line);
    }

    .marquee-inner {
      display: flex;
      gap: 24px;
      animation: scroll 30s linear infinite;
      white-space: nowrap;
    }

    .marquee-inner span {
      display: flex;
      gap: 8px;
      align-items: center;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--forest);
    }

    .marquee-inner i {
      color: var(--green);
      font-style: normal;
    }

    @keyframes scroll {
      to {
        transform: translateX(-50%);
      }
    }

    /* Section Base */
    section {
      padding: 80px 22px;
    }

    h2 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 800;
      margin-bottom: 12px;
      color: var(--forest);
    }

    section > .wrap > p {
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 480px;
      margin-bottom: 40px;
    }

    /* Definition */
    .definition {
      background: #fff;
    }

    .definition-grid {
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 40px;
      background: #fff;
      border-radius: 26px;
      padding: 46px;
      align-items: center;
    }

    .definition-grid .pill {
      margin-bottom: 20px;
    }

    .definition-grid h2 {
      margin-bottom: 20px;
    }

    .definition-grid .stamp {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 20px;
    }

    .definition-grid svg {
      width: 100%;
      height: auto;
    }

    /* Solutions Grid */
    .grid3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .pcard {
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      cursor: pointer;
      transition: 0.28s cubic-bezier(0.2, 0.7, 0.2, 1);
    }

    .pcard:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    }

    .pcard:hover img {
      transform: scale(1.08);
    }

    .pcard img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      transition: 0.6s;
    }

    .pcard .pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding: 16px;
      border-bottom: 1px solid var(--line);
    }

    .pcard .pills .tag {
      background: rgba(60, 104, 77, 0.1);
      color: var(--green);
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 0.72rem;
      font-weight: 600;
    }

    .pcard .pills .tag.bold {
      background: var(--green);
      color: #fff;
    }

    .pcard .content {
      padding: 18px;
    }

    .pcard h3 {
      font-size: 1.28rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .pcard .subtitle {
      font-size: 0.92rem;
      color: var(--muted);
      margin-bottom: 14px;
    }

    .pcard .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      font-size: 0.78rem;
      color: var(--forest);
    }

    .pcard .stats strong {
      display: block;
      font-weight: 700;
      color: var(--green);
    }

    /* Technology */
    .tech {
      background: #fff;
    }

    .tgrid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .tcard {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 28px;
      background: var(--cream);
      border-radius: 18px;
      transition: 0.28s;
    }

    .tcard:hover {
      background: #fff;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }

    .tcard svg {
      width: 48px;
      height: 48px;
      color: var(--green);
      margin-bottom: 14px;
    }

    .tcard h3 {
      font-weight: 700;
      margin-bottom: 10px;
      font-size: 1.05rem;
    }

    .tcard p {
      font-size: 0.92rem;
      color: var(--muted);
    }

    /* Models */
    .mgrid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .mcard {
      background: var(--cream);
      border-radius: 18px;
      padding: 28px;
      border-top: 3px solid var(--green-2);
    }

    .mcard .label {
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--green-2);
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .mcard h3 {
      font-size: 1.28rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .mcard p {
      font-size: 0.92rem;
      color: var(--muted);
      margin-bottom: 16px;
      line-height: 1.6;
    }

    .mcard .note {
      font-size: 0.78rem;
      color: var(--green);
      font-weight: 600;
    }

    /* Advantages */
    .vgrid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 18px;
    }

    .vcard {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding: 22px;
      background: var(--cream);
      border-radius: 16px;
      transition: 0.28s;
    }

    .vcard:hover {
      background: linear-gradient(135deg, rgba(60, 104, 77, 0.08), rgba(79, 119, 71, 0.08));
    }

    .vcard svg {
      width: 36px;
      height: 36px;
      color: var(--green);
      margin-bottom: 12px;
    }

    .vcard h3 {
      font-weight: 700;
      margin-bottom: 8px;
      font-size: 1rem;
    }

    .vcard p {
      font-size: 0.88rem;
      color: var(--muted);
    }

    /* Calculator */
    .calc {
      background: linear-gradient(160deg, #EDF1EA, #E4EBE2);
    }

    .calc > .wrap > h2 {
      text-align: center;
      margin-bottom: 14px;
    }

    .calc > .wrap > p {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 40px;
    }

    .frame {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      background: #fff;
      border-radius: 28px;
      padding: 42px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
      max-width: 1000px;
      margin: 0 auto;
    }

    .frame .label {
      display: block;
      font-weight: 600;
      font-size: 0.92rem;
      margin-bottom: 12px;
      color: var(--forest);
    }

    .seg {
      display: flex;
      gap: 8px;
      margin-bottom: 24px;
    }

    .seg button {
      flex: 1;
      padding: 10px 12px;
      border: 1px solid var(--line);
      background: transparent;
      border-radius: 10px;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--muted);
      cursor: pointer;
      transition: 0.28s;
    }

    .seg button.on {
      background: var(--green);
      color: #fff;
      border-color: var(--green);
    }

    .seg button:hover:not(.on) {
      border-color: var(--green);
      color: var(--green);
    }

    .slider-group {
      margin-bottom: 24px;
    }

    .slider-group .label-val {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }

    input[type="range"] {
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: linear-gradient(to right, var(--green) 0%, var(--green) calc(var(--p, 50%)), var(--line) calc(var(--p, 50%)), var(--line) 100%);
      outline: none;
      -webkit-appearance: none;
    }

    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: var(--green);
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(60, 104, 77, 0.3);
    }

    input[type="range"]::-moz-range-thumb {
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: var(--green);
      cursor: pointer;
      border: none;
      box-shadow: 0 2px 8px rgba(60, 104, 77, 0.3);
    }

    .result {
      background: linear-gradient(160deg, var(--green), var(--forest-2));
      color: #fff;
      border-radius: 18px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .result-item {
      display: flex;
      align-items: baseline;
      gap: 8px;
    }

    .result-item .big {
      font-size: 2.4rem;
      font-weight: 800;
    }

    .result-item small {
      font-size: 0.88rem;
      opacity: 0.9;
      flex: 1;
    }

    .result .boxes {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 12px;
    }

    .result .box {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(8px);
      border-radius: 10px;
      padding: 14px;
      text-align: center;
    }

    .result .box .big {
      display: block;
      margin-bottom: 4px;
    }

    .result .check {
      font-size: 0.88rem;
      opacity: 0.9;
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    .result .check span {
      display: block;
    }

    .result .disclaimer {
      font-size: 0.78rem;
      opacity: 0.75;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

    /* Showcase */
    .showcase {
      background: #fff;
    }

    .showcase .inner {
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      min-height: 540px;
      border-radius: 30px;
      overflow: hidden;
      position: relative;
      background-image: url('https://d8j0ntlcm91z4.cloudfront.net/user_37vskBUfwfE0OUpgvwcfoBpdX9r/hf_20260620_225343_f066b07a-f4a8-4890-a6e3-390f2fa87561.png');
      background-size: cover;
      background-position: center;
    }

    .showcase .ov {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(16, 24, 19, 0.6), rgba(16, 24, 19, 0.3));
    }

    .showcase .content {
      position: relative;
      z-index: 2;
      color: #fff;
      max-width: 640px;
      padding: 40px;
    }

    .showcase .content .pill {
      margin-bottom: 18px;
    }

    .showcase .content h2 {
      color: #fff;
      margin-bottom: 16px;
    }

    .showcase .content > p {
      color: rgba(255, 255, 255, 0.85);
      font-size: 1.05rem;
      margin-bottom: 28px;
    }

    .flist {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .flist-item {
      display: flex;
      gap: 12px;
    }

    .flist-item svg {
      width: 32px;
      height: 32px;
      color: var(--green);
      flex-shrink: 0;
    }

    .flist-item h4 {
      font-weight: 700;
      margin-bottom: 4px;
      font-size: 0.95rem;
    }

    .flist-item small {
      display: block;
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.7);
    }

    /* FAQ */
    .faq-list {
      max-width: 840px;
      margin: 0 auto;
    }

    .faq-item {
      background: var(--cream);
      border-radius: 12px;
      margin-bottom: 12px;
      overflow: hidden;
      border: 1px solid var(--line);
    }

    .faq-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 22px;
      cursor: pointer;
      transition: 0.28s;
    }

    .faq-head:hover {
      background: rgba(60, 104, 77, 0.04);
    }

    .faq-head strong {
      font-weight: 700;
      font-size: 1rem;
    }

    .faq-head .icon {
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: var(--green);
      transition: 0.28s;
    }

    .faq-item.open .icon {
      transform: rotate(45deg);
    }

    .faq-body {
      max-height: 0;
      overflow: hidden;
      transition: 0.28s;
      background: #fff;
    }

    .faq-item.open .faq-body {
      max-height: 400px;
    }

    .faq-body > div {
      padding: 0 22px 22px;
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.7;
    }

    /* Closing CTA */
    .close {
      background: linear-gradient(135deg, var(--green) 0%, var(--forest-2) 100%);
    }

    .close-grid {
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 40px;
      background: transparent;
      padding: 0;
      align-items: center;
    }

    .close h2 {
      color: #fff;
      margin-bottom: 16px;
    }

    .close > .wrap > p {
      color: rgba(255, 255, 255, 0.85);
    }

    .close .side {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .close .side p {
      color: rgba(255, 255, 255, 0.85);
    }

    .close .side strong {
      color: #fff;
      font-weight: 700;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .navpill .links {
        display: none;
      }

