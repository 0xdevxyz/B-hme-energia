---
// apps/web/src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Values from '../components/Values.astro';
import Calculator from '../components/Calculator.tsx';
import Process from '../components/Process.astro';
import Comparison from '../components/Comparison.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';

const cmsUrl = import.meta.env.PUBLIC_CMS_URL;

let pageContent = {
  hero: {
    title: 'Wärme ohne Sorgen',
    subtitle: 'Wir finanzieren, bauen und betreiben. Sie zahlen nur die Wärme, die Sie nutzen.',
    backgroundImage: 'https://images.pexels.com/photos/5632399/pexels-photo-5632399.jpeg',
  },
  values: [],
  process: [],
  testimonials: [],
};

try {
  const response = await fetch(`${cmsUrl}/api/pages?where[slug][equals]=onepager`);
  const data = await response.json();
  if (data.docs && data.docs.length > 0) {
    pageContent = {
      hero: data.docs[0].hero || pageContent.hero,
      values: data.docs[0].values || pageContent.values,
      process: data.docs[0].process || pageContent.process,
      testimonials: data.docs[0].testimonials || pageContent.testimonials,
    };
  }
} catch (error) {
  console.error('Failed to fetch page content:', error);
}
---

<Layout title="Böhme Energia - Wärmecontracting ohne Investitionskosten">
  <Hero
    title={pageContent.hero.title}
    subtitle={pageContent.hero.subtitle}
    backgroundImage={pageContent.hero.backgroundImage}
    ctaText={pageContent.hero.ctaText || 'Kostenlos Angebot erhalten'}
  />

  <Values values={pageContent.values} />

  <Calculator client:load />

  <Process steps={pageContent.process} />

  <Comparison />

  <Testimonials testimonials={pageContent.testimonials} />

  <CTA />
</Layout>
