---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Values from '../components/Values.astro';
import Audience from '../components/Audience.astro';
import Process from '../components/Process.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
---

<Layout
  title="Wärmecontracting Sachsen | Böhme Energia GmbH Mühlau"
  description="Moderne Wärme ohne Investitionskosten — für Privat & Gewerbe in Sachsen. Wärmepumpe, Fernwärme, BHKW im Contracting. Jetzt anfragen."
  canonical="https://boehme-energia.com/"
>
  <Nav />

  <main class="w-full overflow-x-hidden">
    <Hero
      title="Wärme, um die Sie sich nicht kümmern müssen"
      subtitle="Wir planen, finanzieren, bauen und betreiben Ihre Wärmeversorgung — Sie zahlen nur die Wärme, die Sie nutzen."
    />

    <Values />

    <Audience />

    <Process />

    <FAQ />

    <CTA />
  </main>
</Layout>
