---
// apps/web/src/pages/blog/[slug].astro
import Layout from '../../layouts/Layout.astro';

const cmsUrl = import.meta.env.PUBLIC_CMS_URL;
const { slug } = Astro.params;

let post: any = null;

try {
  const response = await fetch(`${cmsUrl}/api/posts?where[slug][equals]=${slug}`);
  const data = await response.json();
  if (data.docs && data.docs.length > 0) {
    post = data.docs[0];
  }
} catch (error) {
  console.error('Failed to fetch blog post:', error);
}

if (!post) {
  return Astro.redirect('/blog');
}
---

<Layout title={post.title}>
  <article class="bg-white py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <header class="mb-12">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-xs font-semibold uppercase text-orange-600">
            {post.category || 'News'}
          </span>
          <span class="text-gray-600">
            {new Date(post.publishedAt).toLocaleDateString('de-DE', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            })}
          </span>
        </div>

        <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-4">
          {post.title}
        </h1>

        <p class="text-xl text-gray-600">
          {post.excerpt}
        </p>

        {post.author && (
          <div class="mt-6 pt-6 border-t border-gray-200">
            <p class="text-sm text-gray-600">
              <span class="font-semibold text-gray-900">Von:</span> {post.author}
            </p>
          </div>
        )}
      </header>

      {post.featuredImage && (
        <img
          src={`${cmsUrl}${post.featuredImage.url}`}
          alt={post.title}
          class="w-full h-96 object-cover rounded-lg mb-12"
        />
      )}

      <div class="prose prose-lg max-w-none mb-12">
        {post.content && <div set:html={post.content} />}
      </div>

      <a
        href="/blog"
        class="inline-block mt-8 text-orange-600 font-semibold hover:text-orange-700"
      >
        ← Zurück zum Blog
      </a>
    </div>
  </article>
</Layout>

<style>
  :global(.prose) {
    color: #4b5563;
  }

  :global(.prose h2) {
    font-size: 2rem;
    font-weight: 700;
    color: #1f2937;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  :global(.prose p) {
    margin-bottom: 1.25rem;
    line-height: 1.75;
  }

  :global(.prose a) {
    color: #ea580c;
    font-weight: 500;
  }
</style>
