---
// apps/web/src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';

const cmsUrl = import.meta.env.PUBLIC_CMS_URL;

let posts: any[] = [];

try {
  const response = await fetch(`${cmsUrl}/api/posts?limit=100&sort=-publishedAt`);
  const data = await response.json();
  posts = data.docs || [];
} catch (error) {
  console.error('Failed to fetch blog posts:', error);
}
---

<Layout title="Blog - Böhme Energia">
  <section class="bg-white py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-6xl font-bold text-gray-900 mb-4">
        Blog & Insights
      </h1>
      <p class="text-xl text-gray-600 mb-16">
        Tipps, News und Know-how rund um Wärmecontracting
      </p>

      {posts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-gray-600">Noch keine Blog-Artikel vorhanden.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group">
              <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
                {post.featuredImage && (
                  <img
                    src={`${cmsUrl}${post.featuredImage.url}`}
                    alt={post.title}
                    class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                )}
                <div class="p-6">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-xs font-semibold uppercase text-orange-600">
                      {post.category || 'News'}
                    </span>
                    <span class="text-xs text-gray-500">
                      {new Date(post.publishedAt).toLocaleDateString('de-DE')}
                    </span>
                  </div>
                  <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-orange-600 transition-colors">
                    {post.title}
                  </h3>
                  <p class="text-gray-600 mb-4 line-clamp-2">
                    {post.excerpt}
                  </p>
                  <span class="text-orange-600 font-semibold text-sm">
                    Mehr lesen →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
