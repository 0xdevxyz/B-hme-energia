---
// apps/web/src/components/Hero.astro
export interface Props {
  title: string;
  subtitle: string;
  backgroundImage?: string;
  ctaText?: string;
}

const { title, subtitle, backgroundImage = 'https://images.pexels.com/photos/5632399/pexels-photo-5632399.jpeg', ctaText = 'Kostenlos Angebot erhalten' } = Astro.props;
---

<section
  class="hero min-h-screen flex items-center justify-center relative overflow-hidden"
  style={`background-image: linear-gradient(135deg, rgba(19,78,72,0.7) 0%, rgba(33,28,24,0.85) 100%), url('${backgroundImage}'); background-size: cover; background-position: center; background-attachment: fixed;`}
>
  <div class="hero-content text-center px-6 max-w-3xl mx-auto z-10">
    <h1 class="text-7xl md:text-8xl font-bold text-white mb-6 leading-tight drop-shadow-lg">
      {title}
    </h1>
    <p class="text-xl md:text-2xl text-gray-100 mb-12 leading-relaxed font-light drop-shadow-md max-w-2xl mx-auto">
      {subtitle}
    </p>
    <button
      class="px-12 py-4 bg-orange-600 hover:bg-orange-700 text-white rounded-full font-semibold text-lg transition-all duration-300 transform hover:scale-105 hover:shadow-2xl"
      onclick="document.querySelector('[data-section=cta]').scrollIntoView({behavior: 'smooth'})"
    >
      {ctaText}
    </button>
  </div>
</section>

<style>
  .hero {
    background-attachment: fixed;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      background-attachment: scroll;
    }
  }
</style>
