---
export interface Props {
  title: string;
  subtitle: string;
  backgroundImage?: string;
  ctaText?: string;
}

const {
  title,
  subtitle,
  backgroundImage = 'https://picsum.photos/seed/heatpump-modern-home/1600/900',
  ctaText = 'Unverbindliches Wärmeangebot anfragen'
} = Astro.props;
---

<section class="hero min-h-[100dvh] pt-24 flex items-center justify-center relative overflow-hidden">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 px-6 md:px-8 items-center py-20 md:py-0 w-full">
    <!-- Text Content (Left) -->
    <div class="z-10">
      <h1 class="text-5xl md:text-6xl font-serif font-bold text-text leading-tight mb-6">
        Wärme, um die Sie sich<br /><span class="text-petrol">nicht kümmern</span> müssen
      </h1>
      <p class="text-lg text-text-leise leading-relaxed max-w-sm mb-8">
        Wir planen, finanzieren, bauen und betreiben Ihre Wärmeversorgung. Sie zahlen nur die Wärme, die Sie nutzen.
      </p>
      <a
        href="#kontakt"
        class="inline-block bg-glut hover:bg-glut-hell text-weiss px-8 py-4 rounded-full font-semibold transition-all duration-300 hover:shadow-lg active:scale-95"
      >
        {ctaText}
      </a>
    </div>

    <!-- Image (Right) -->
    <div class="relative hidden md:block">
      <img
        src={backgroundImage}
        alt="Moderne Wärmepumpe Installation"
        class="w-full h-auto rounded-2xl shadow-xl object-cover max-h-[600px]"
      />
      <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-anthrazit/10 to-transparent pointer-events-none" />
    </div>
  </div>
</section>
