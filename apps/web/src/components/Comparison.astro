---
// apps/web/src/components/Comparison.astro
---

<section class="bg-white py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-5xl md:text-6xl font-bold text-gray-900 mb-4 text-center">
      Privat vs. Gewerbe
    </h2>
    <p class="text-xl text-gray-600 mb-16 text-center">
      Maßgeschneiderte Lösungen für Ihre Anforderungen
    </p>

    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b-2 border-gray-200">
            <th class="text-left py-4 px-6 font-bold text-gray-900">Feature</th>
            <th class="text-center py-4 px-6 font-bold text-teal-700">Privatkunden</th>
            <th class="text-center py-4 px-6 font-bold text-green-600">Gewerbe & Kommunen</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-gray-200">
            <td class="py-4 px-6 text-gray-600">Investitionskosten</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">0 €</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">0 €</td>
          </tr>
          <tr class="border-b border-gray-200">
            <td class="py-4 px-6 text-gray-600">Finanzierung</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">Vollständig</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">Vollständig</td>
          </tr>
          <tr class="border-b border-gray-200">
            <td class="py-4 px-6 text-gray-600">Wartung</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">Inklusive</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">Inklusive</td>
          </tr>
          <tr class="border-b border-gray-200">
            <td class="py-4 px-6 text-gray-600">Durchschnittliche Einsparungen</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">bis 25%</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">bis 30%</td>
          </tr>
          <tr>
            <td class="py-4 px-6 text-gray-600">Mindestlaufzeit</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">10 Jahre</td>
            <td class="text-center py-4 px-6 font-semibold text-gray-900">12 Jahre</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
