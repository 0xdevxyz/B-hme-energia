---
// apps/web/src/components/Values.astro
export interface Props {
  values?: Array<{
    icon: string;
    title: string;
    description: string;
  }>;
}

const { values = [] } = Astro.props;

const defaultValues = [
  {
    icon: '✓',
    title: 'Ausgereifte Technik',
    description: 'Bewährte Anlagen, regelmäßige Wartung, 24/7-Service. Zuverlässig seit Jahrzehnten.',
  },
  {
    icon: '✓',
    title: '0 Euro Investition',
    description: 'Wir finanzieren komplett. Sie zahlen planbare monatliche Raten für Wärmemengen.',
  },
  {
    icon: '✓',
    title: 'Nachhaltig & Modern',
    description: 'Weniger CO₂, höhere Nutzungsgrade, erneuerbare Optionen. Zukunftssicher.',
  },
];

const displayValues = values.length > 0 ? values : defaultValues;
---

<section class="bg-amber-50 py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-5xl md:text-6xl font-bold text-gray-900 mb-4">
      Drei Gründe für Wärmecontracting
    </h2>
    <p class="text-xl text-gray-600 mb-16">
      Moderne Wärmeversorung — bewährt, nachhaltig, investitionsfrei.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {displayValues.map((value) => (
        <div class="animate-fade-in">
          <div class="text-6xl text-orange-600 mb-6">{value.icon}</div>
          <h3 class="text-2xl font-bold text-teal-700 mb-4">{value.title}</h3>
          <p class="text-gray-600 leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }

  .animate-fade-in:nth-child(2) {
    animation-delay: 0.1s;
  }

  .animate-fade-in:nth-child(3) {
    animation-delay: 0.2s;
  }
</style>
