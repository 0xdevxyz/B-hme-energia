---
export interface Props {
  values?: Array<{
    title: string;
    description: string;
  }>;
}

const { values = [] } = Astro.props;

const defaultValues = [
  {
    title: 'Ausgereifte, bewährte Technik',
    description: 'Geprüfte Anlagen, regelmäßige Wartung, 24/7-Entstördienst.',
  },
  {
    title: 'Nachhaltig & effizient',
    description: 'Moderne Wärmeerzeugung, hohe Nutzungsgrade, optionaler Ökostrom-/Biogasanteil.',
  },
  {
    title: 'CO₂ reduzieren',
    description: 'Weniger Emissionen pro Kilowattstunde, transparente CO₂-Bilanz für Ihr Objekt.',
  },
];

const displayValues = values.length > 0 ? values : defaultValues;
---

<section class="py-24 md:py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-serif font-bold text-text mb-6 leading-tight">
      Ihre Vorteile auf einen Blick
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {displayValues.map((value, i) => (
        <div
          class="bg-weiss border border-leinen rounded-2xl p-8 hover:shadow-md transition-shadow"
          style={`animation: fadeIn 0.6s ease-out ${i * 0.1}s forwards; opacity: 0;`}
        >
          <div class="flex items-start gap-4 mb-6">
            <svg class="w-6 h-6 text-salbei flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <h3 class="text-lg font-semibold text-text">{value.title}</h3>
          </div>
          <p class="text-text-leise leading-relaxed text-sm">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    * {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>
