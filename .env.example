# Kopiere diese Datei zu .env und fülle deine Werte ein

# MongoDB Atlas Connection String
DATABASE_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/boehme

# Payload CMS Secrets
PAYLOAD_SECRET=your-super-secret-key-here
PAYLOAD_PUBLIC_SERVER_URL=https://cms-boehme.deine-domain.de

# Astro Web App
PUBLIC_CMS_URL=https://cms-boehme.deine-domain.de
CMS_URL=https://cms-boehme.deine-domain.de

# Environment
NODE_ENV=production
PORT=3000
